{
    "name": "neverwrite-web-clipper",
    "description": "NeverWrite browser extension built as an isolated WXT app inside the monorepo.",
    "private": true,
    "version": "0.2.4",
    "type": "module",
    "packageManager": "pnpm@10.33.0",
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "dev": "wxt",
        "dev:firefox": "wxt -b firefox",
        "build": "pnpm run build:wxt && node ./scripts/sync-build-output.mjs",
        "build:wxt": "pnpm run build:chrome && pnpm run build:firefox",
        "build:chrome": "wxt build -b chrome",
        "build:firefox": "wxt build -b firefox",
        "zip": "pnpm run zip:chrome && pnpm run zip:firefox",
        "zip:chrome": "wxt zip -b chrome",
        "zip:firefox": "wxt zip -b firefox",
        "compile": "tsc --noEmit",
        "check": "pnpm run compile && pnpm run test:run && pnpm run build",
        "test": "vitest",
        "test:run": "vitest run",
        "postinstall": "wxt prepare"
    },
    "dependencies": {
        "defuddle": "^0.14.0",
        "dompurify": "^3.4.1",
        "react": "^19.2.5",
        "react-dom": "^19.2.5"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.2.4",
        "@types/jsdom": "^21.1.7",
        "@types/node": "^24.12.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@wxt-dev/module-react": "^1.2.2",
        "jsdom": "^26.1.0",
        "tailwindcss": "^4.2.4",
        "typescript": "^6.0.3",
        "vitest": "^4.1.5",
        "wxt": "^0.20.25"
    }
}
