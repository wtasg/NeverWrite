        "jsdom": "^26.1.0",
        "rcedit": "^5.0.2",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.0",
        "vite": "^8.0.10",
        "vitest": "^4.1.5",
        "yaml": "^2.8.3"
    },
    "overrides": {
        "@chevrotain/cst-dts-gen": {
            "lodash-es": "4.18.1"
        },
        "@chevrotain/gast": {
            "lodash-es": "4.18.1"
