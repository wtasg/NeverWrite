{
    "name": "desktop",
    "private": true,
    "version": "0.2.4",
    "type": "module",
    "main": "out/electron/main/index.js",
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "dev": "node scripts/run-electron-dev.mjs",
        "renderer:dev": "vite",
        "build": "tsc -b && vite build",
        "lint": "eslint .",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:split-grid-baseline": "vitest run src/app/store/workspaceLayoutTree.test.ts src/app/store/workspaceLayoutNavigation.test.ts src/app/store/editorStore.test.ts src/app/store/editorSession.test.ts src/app/store/layoutStore.test.ts src/features/editor/MultiPaneWorkspace.test.tsx src/features/editor/EditorPaneBar.test.tsx src/features/editor/workspaceTabDropPreview.test.ts src/features/editor/UnifiedBar.test.tsx src/features/vault/FileTree.test.tsx src/features/ai/components/reviewMultiSessionIntegration.test.tsx src/features/ai/components/AIReviewView.test.tsx",
        "preview": "vite preview",
        "electron:dev": "node scripts/run-electron-dev.mjs",
        "electron:build": "node scripts/build-electron.mjs",
        "electron:sidecar:build": "cargo build -p neverwrite-native-backend",
        "electron:sidecar:build:release": "cargo build -p neverwrite-native-backend --release",
        "electron:sidecar:stage": "node scripts/stage-electron-sidecar.mjs",
        "electron:app:smoke:packaged": "node scripts/smoke-packaged-app.mjs",
        "electron:sidecar:smoke:packaged": "node scripts/smoke-packaged-sidecar.mjs",
        "electron:vault-editor:smoke": "node scripts/smoke-electron-vault-editor.mjs",
        "electron:ai-runtime:smoke": "node scripts/smoke-electron-ai-runtime.mjs",
        "electron:package": "node scripts/build-electron-release.mjs --dir",
        "electron:package:unsigned": "node scripts/build-electron-release.mjs --dir --unsigned",
        "electron:dist:mac": "node scripts/build-electron-release.mjs --platform mac",
        "electron:dist:win": "node scripts/build-electron-release.mjs --platform win",
        "electron:release:local": "node scripts/build-electron-release.mjs"
    },
    "dependencies": {
        "@codemirror/commands": "^6.10.3",
