        "@codemirror/search": "^6.7.0",
        "@codemirror/state": "^6.6.0",
        "@codemirror/theme-one-dark": "^6.1.3",
        "@codemirror/view": "^6.41.1",
        "@excalidraw/excalidraw": "^0.18.1",
        "@iconify-json/catppuccin": "^1.2.17",
        "@lezer/common": "^1.5.2",
